# This file is a template for environment variables. Copy it to .env and fill in the values.
#
# This should point to the url for your api, which is typically http://localhost:3001/v1 for local development,
# and the URL of your deployed API in production.
NEXT_PUBLIC_API_URL=http://localhost:3001/v1

# Secret used to encrypt the server-side session cookie (iron-session).
# Must be at least 32 characters. Generate a value with: openssl rand -base64 32
# Never expose this value or commit it to source control.
SESSION_SECRET=change-me-to-a-random-32-char-secret-value!!
